# ═════════════════════════════════════════════════════════
#  Football Prediction — Environment Variables
#  Copy this file to .env and fill in your values.
#  ⚠ .env is gitignored — never commit secrets!
# ═════════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_DEBUG=true               # true | false
SECRET_KEY=change-me-in-production

# ── Database (PostgreSQL) ──────────────────────────────
# Full URL takes precedence over individual components.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/football_prediction

DB_HOST=localhost
DB_PORT=5432
DB_NAME=football_prediction
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_PRE_PING=true
DB_ECHO=false               # Set true to log all SQL

# ── Logging ─────────────────────────────────────────────
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
LOG_FILE=true                # true | false

# ── External APIs ──────────────────────────────────────
# Sign up at https://www.football-data.org/ to get a free API key.
FOOTBALL_DATA_API_KEY=

# Sign up at https://the-odds-api.com/ to get a free API key.
THE_ODDS_API_KEY=
