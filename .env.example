# ═════════════════════════════════════════════════════════
#  Football Prediction — Environment Variables
#  Copy this file to .env and fill in your values.
#  ⚠ .env is gitignored — never commit secrets!
# ═════════════════════════════════════════════════════════
#
# Required in production:
#   PREDICTION_API_KEY    — API authentication key
#   DATABASE_URL          — Database connection string
#

# ── Application ─────────────────────────────────────────
# APP_ENV=development    # development | production (default: production)
# APP_DEBUG=true          # true | false

# ── Database (PostgreSQL) ──────────────────────────────
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/football_prediction
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=football_prediction
# DB_USER=postgres

# ── Logging ─────────────────────────────────────────────
# LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR

# ── External APIs ──────────────────────────────────────
# Sign up at https://www.football-data.org/ to get a free API key.
# FOOTBALL_DATA_API_KEY=

# Sign up at https://the-odds-api.com/ to get a free API key.
# THE_ODDS_API_KEY=

# ── API Authentication ─────────────────────────────────
# PREDICTION_API_KEY=change-this-in-production
